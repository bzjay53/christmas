rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 사용자 인증 체크 함수
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // 사용자 본인 체크 함수
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // 관리자 체크 함수
    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/admin_users/$(request.auth.uid));
    }

    // 서비스 계정 체크 함수
    function isServiceAccount() {
      return isAuthenticated() && 
             request.auth.token.firebase.sign_in_provider == 'custom';
    }

    // 사용자 프로필 데이터
    match /users/{userId} {
      allow read, write: if isAuthenticated() && (isOwner(userId) || isAdmin());
      
      // 사용자 하위 컬렉션들
      match /trading_orders/{orderId} {
        allow read, write: if isAuthenticated() && (isOwner(userId) || isServiceAccount());
      }
      
      match /portfolio/{portfolioId} {
        allow read, write: if isAuthenticated() && (isOwner(userId) || isServiceAccount());
      }
      
      match /ai_learning/{learningId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow write: if isServiceAccount();
      }
      
      match /notifications/{notificationId} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }
    }

    // 전역 시장 데이터 (읽기 전용)
    match /market_data/{stockCode} {
      allow read: if isAuthenticated();
      allow write: if isServiceAccount();
    }

    // AI 분석 결과 (읽기 전용)
    match /ai_analysis/{analysisId} {
      allow read: if isAuthenticated();
      allow write: if isServiceAccount();
    }

    // 시스템 설정 (관리자만)
    match /system_config/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isServiceAccount();
    }

    // 트레이딩 큐 (서버 전용)
    match /trading_queue/{queueId} {
      allow read, write: if isServiceAccount();
    }

    // 시스템 로그 (서버 전용)
    match /system_logs/{logId} {
      allow read: if isAdmin();
      allow write: if isServiceAccount();
    }

    // 헬스체크 (모든 인증된 사용자 읽기, 서버만 쓰기)
    match /_health_check/{docId} {
      allow read: if isAuthenticated();
      allow write: if isServiceAccount();
    }

    // 기본적으로 모든 접근 거부
    match /{document=**} {
      allow read, write: if false;
    }
  }
}