# Firebase Configuration
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-private-key-content\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_SERVICE_ACCOUNT_FILE=/path/to/service-account.json

# Redis Configuration
REDIS_URL=redis://localhost:6379

# KIS API Configuration (Korean Investment & Securities)
KIS_APP_KEY=your-kis-app-key
KIS_APP_SECRET=your-kis-app-secret
KIS_BASE_URL=https://openapivts.koreainvestment.com:29443
KIS_ACCOUNT_NUMBER=your-account-number
KIS_ACCOUNT_CODE=01

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Security Configuration
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application Configuration
DEBUG=false
LOG_LEVEL=INFO
ENVIRONMENT=production

# Trading Configuration
DEFAULT_STOP_LOSS=-0.02
DEFAULT_TAKE_PROFIT=0.05
MAX_DAILY_TRADES=20
QUEUE_DELAY_SECONDS=10

# AI Configuration
AI_CONFIDENCE_THRESHOLD=0.7
LEARNING_UPDATE_FREQUENCY=weekly
BACKTEST_PERIOD_DAYS=30