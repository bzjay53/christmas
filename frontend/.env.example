# Christmas Trading 프론트엔드 환경변수 예시 파일
# 실제 사용시 .env 파일로 복사하여 값들을 설정하세요

# 애플리케이션 설정
VITE_APP_NAME=Christmas Trading
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# API 설정
VITE_API_URL=http://localhost:8000
VITE_API_TIMEOUT=30000

# Firebase 설정
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Firebase 에뮬레이터 설정 (개발용)
VITE_USE_FIREBASE_EMULATOR=false
VITE_FIREBASE_EMULATOR_AUTH_URL=http://localhost:9099
VITE_FIREBASE_EMULATOR_FIRESTORE_URL=http://localhost:8080

# KIS API 설정 (프론트엔드에서는 숨김 처리)
VITE_KIS_MOCK_MODE=true

# 외부 서비스 설정
VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
VITE_SENTRY_DSN=https://your_sentry_dsn_here

# 기능 플래그
VITE_ENABLE_TRADING=true
VITE_ENABLE_AI_ANALYSIS=true
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_DARK_MODE=true

# 개발/디버그 설정
VITE_DEBUG_MODE=false
VITE_LOG_LEVEL=info
VITE_SHOW_PERFORMANCE_MONITOR=false

# PWA 설정
VITE_PWA_ENABLED=true
VITE_PWA_OFFLINE_ENABLED=true

# 소셜 로그인 설정 (향후 기능)
VITE_GOOGLE_CLIENT_ID=your_google_client_id
VITE_KAKAO_CLIENT_ID=your_kakao_client_id
VITE_NAVER_CLIENT_ID=your_naver_client_id